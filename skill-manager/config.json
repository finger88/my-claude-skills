{
  "git": {
    "autoCommit": true,
    "autoPush": true,
    "autoUpdateReadme": true,
    "commitTemplate": "chore(skills): {message}",
    "alwaysSignoff": false
  },
  "backup": {
    "skipUnchanged": true,
    "includeRefs": true,
    "includeScripts": true,
    "includeAssets": true
  },
  "evaluate": {
    "exportReport": true,
    "showDetail": false
  },
  "diff": {
    "defaultMode": "stat",
    "contextLines": 3
  }
}
